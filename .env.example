# Copy to .env and fill in. The app reads these on startup.

# --- Audio provider API keys ---
# If a key is missing (or FINETUNES_USE_MOCK=true), that provider falls back to a
# local mock generator so the full experiment flow still works without credits.
ELEVENLABS_API_KEY=

# Stable Audio runs via fal.ai (Stable Audio 3.0). Without FAL_KEY the
# stable_audio side falls back to the local mock generator.
# Get a key at https://fal.ai/dashboard/keys
FAL_KEY=

# Model versions are pinned in code to the latest: ElevenLabs Music v2 and
# Stable Audio 3.0 (fal). See finetunes/providers/.

# Force the mock generator for both providers (handy for local UI work).
# Set to "true" to never call the real APIs.
FINETUNES_USE_MOCK=false

# --- App config ---
# SQLAlchemy database URL. Defaults to a local SQLite file next to the app.
# Swap for Postgres later, e.g. postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///finetunes.db

# Where generated audio files are written (one subdir per experiment).
AUDIO_STORAGE_DIR=storage

# Flask secret (only used for flashing; any random string is fine locally).
SECRET_KEY=dev-secret-change-me
